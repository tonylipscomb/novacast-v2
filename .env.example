# Expo-safe public configuration. These values are safe to ship to the TV app.
EXPO_PUBLIC_NOVACAST_PAIRING_API_URL=https://YOUR_PROJECT.supabase.co/functions/v1
EXPO_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key
EXPO_PUBLIC_NOVACAST_PAIRING_WEBSITE_URL=https://pair.example.com/pair

# Device foundation / closed beta rollout flags.
EXPO_PUBLIC_DEVICE_REGISTRATION_ENABLED=true
EXPO_PUBLIC_DEVICE_ACTIVATION_ENABLED=true
EXPO_PUBLIC_DEVICE_ACTIVATION_REQUIRED=false
EXPO_PUBLIC_BETA_INVITES_ENABLED=true
EXPO_PUBLIC_MANAGED_BETA_PROVIDER_ENABLED=false
EXPO_PUBLIC_PERSONAL_PROVIDER_PAIRING_ENABLED=true

# Closed beta mode: invite code → managed provider → Home (pairing website bypassed).
# When true, activation is required, managed provider download is enabled, and personal pairing is inactive.
EXPO_PUBLIC_CLOSED_BETA_MODE=false

# Do not add provider usernames, passwords, service-role keys, or encryption keys here.
